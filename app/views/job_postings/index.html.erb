<h1>Top Shelf Rolez</h1>

<%= form_with url: root_path, method: :get, local: true do %>
  <div style="margin-bottom:20px">

    <%= label_tag :title, "Title" %>
    <%= text_field_tag :title, params[:title] %>

    <%= label_tag :company, "Company" %>
    <%= text_field_tag :company, params[:company] %>

    <%= label_tag :location, "Location" %>
    <%= select_tag :location,
      options_for_select(
        [
          ["All", ""],
          ["United States", "us"],
          ["Colorado", "colorado"]
        ],
        params[:location]
      ) %>

    <%= label_tag :status, "Status" %>
    <%= select_tag :status,
      options_for_select(
        [
          ["All", ""],
          ["new", "new"],
          ["saved", "saved"],
          ["applied", "applied"],
          ["dismissed", "dismissed"]
        ],
        params[:status]
      ) %>

    <%= label_tag :remote, "Remote only" %>
    <%= check_box_tag :remote, "1", params[:remote] == "1" %>

    <%= label_tag :sort, "Sort" %>
    <%= select_tag :sort,
      options_for_select(
        [
          ["Best Match", "ai"],
          ["Most Recent", "recent"]
        ],
        params[:sort]
      ) %>

    <%= submit_tag "Filter" %>

    <%= button_to "Refresh Jobs",
      "/jobs/refresh",
      method: :post,
      style: "margin-left:10px;" %>

  </div>
<% end %>


<table border="1" cellpadding="8" cellspacing="0">
  <thead>
    <tr>
      <th>Score</th>
      <th>Company</th>
      <th>Title</th>
      <th>Location</th>
      <th>Remote</th>
      <th>Posted</th>
      <th>Status</th>
      <th>Apply</th>
      <th>Analyze</th>
      <th>Cover Letter</th>
      <th>Resume</th>
      <th>PDF</th>
      <th>Update</th>
    </tr>
  </thead>

  <tbody>
    <% @job_postings.each do |job| %>
      <tr>

        <!-- Score -->
        <td class="
          <% if job.ai_score.to_i >= 80 %>
            score-high
          <% elsif job.ai_score.to_i >= 60 %>
            score-mid
          <% else %>
            score-low
          <% end %>
        ">
          <%= job.ai_score || 0 %>
        </td>

        <!-- Company -->
        <td><%= job.company&.name %></td>

        <!-- Title -->
        <td>
          <%= link_to job.title, job_posting_path(job) %>
        </td>

        <!-- Location -->
        <td>
          <%= job.location %>
        </td>

        <!-- Remote -->
        <td>
          <%= job.remote ? "Yes" : "No" %>
        </td>

        <!-- Posted -->
        <td>
          <%= job.posted_at&.to_date %>
        </td>

        <!-- Status -->
        <td>
          <%= job.status.presence || "new" %>
        </td>

        <!-- Apply -->
        <td>
          <%= link_to "Apply", job.apply_url, target: "_blank", rel: "noopener" %>
        </td>

        <!-- Analyze -->
        <td>
          <%= link_to "Analyze",
              analyze_job_posting_path(job),
              target: "_blank" %>
        </td>

        <!-- Cover Letter -->
        <td>
          <%= link_to "Generate Cover Letter",
              cover_letter_job_posting_path(job),
              target: "_blank" %>
        </td>

        <!-- Resume -->
        <td>
          <%= link_to "Generate Resume",
              resume_job_posting_path(job),
              class: "btn btn-primary",
              target: "_blank" %>
        </td>

        <!-- Download PDF -->
        <td>
          <%= link_to "Download Resume PDF",
          download_resume_job_posting_path(job),
          class: "btn btn-primary",
          target: "_blank" %>
        </td>

        <td>
        <%= link_to "Download DOCX",
    download_resume_docx_job_posting_path(job),
    class: "btn btn-primary",
    target: "_blank" %>
    </td>
    
        <!-- Update Status -->
        <td>
          <%= form_with model: job, method: :patch, local: true do |f| %>
            <%= f.select :status, JobPosting::STATUSES, selected: job.status.presence || "new" %>
            <%= f.submit "Save" %>
          <% end %>
        </td>

      </tr>
    <% end %>
  </tbody>
</table>